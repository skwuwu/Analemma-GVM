# Architecture spec
Analemma-GVM-architecture-*

# Rust
**/target/
**/*.rs.bk
# Cargo.lock is tracked for reproducible builds (binary project)

# IDE
.idea/
.vscode/
*.swp
*.swo
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc

# Environment
.env
.env.local
.env.production
!.env.example

# Build artifacts
*.exe
*.dll
*.so
*.dylib

# Fuzz
fuzz/corpus/
fuzz/artifacts/

# Runtime data (generated by proxy at startup / runtime)
data/wal.log
data/wal.log.watermark
data/wal_emergency.log
data/proxy.log
data/proxy.pid
# MITM CA was previously persisted at these paths. Since CA-5 the
# legacy CA is RAM-only and per-sandbox CAs are also RAM-only — these
# files should not exist in any working tree. Kept in .gitignore as a
# guard so a hand-edited CA file (e.g. for a one-off mitmproxy-style
# debug session) doesn't accidentally get committed.
data/mitm-ca.pem
data/mitm-ca-key.pem

# Wasm engine binary (compiled artifact, not source)
data/gvm_engine.wasm

# Test results (generated per-run, not source)
results/

# Workspace output (agent-generated files)
workspace/output/

# Fuzz workspace lock (not needed for reproducibility — fuzz/ has its own Cargo.toml)
fuzz/Cargo.lock

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock
