# Analemma-GVM — API Credentials (Layer 3: API Key Isolation)
#
# Copy this file to secrets.toml and fill in your credentials:
#   cp secrets.toml.example secrets.toml
#
# When credentials are configured here, the proxy injects them into
# forwarded requests automatically. Agents never see the raw API keys.
# This is Layer 3 of GVM's security model.
#
# Without credentials: agents must carry their own API keys (passthrough mode).
# With credentials: only the proxy holds keys — agents cannot bypass governance.
#
# In production, encrypt this file:
#   gvm secrets encrypt --key $GVM_SECRETS_KEY

[credentials."api.stripe.com"]
type = "ApiKey"
header = "Authorization"
value = "Bearer sk_test_your-stripe-key-here"

[credentials."api.slack.com"]
type = "Bearer"
token = "xoxb-your-slack-bot-token-here"

[credentials."gmail.googleapis.com"]
type = "Bearer"
token = "ya29.your-google-oauth-token-here"
