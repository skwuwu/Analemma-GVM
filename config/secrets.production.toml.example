# ════════════════════════════════════════════════════════════════════
# GVM Secrets — Production Template
# ════════════════════════════════════════════════════════════════════
#
# Setup:
#   sudo install -d -o gvm -g gvm -m 0700 /etc/gvm
#   cp config/secrets.production.toml.example /etc/gvm/secrets.toml
#   sudo chown gvm:gvm /etc/gvm/secrets.toml
#   sudo chmod 0600 /etc/gvm/secrets.toml
#   # Then encrypt at rest:
#   gvm secrets encrypt --key "$GVM_SECRETS_KEY" /etc/gvm/secrets.toml
#
# Security checklist before going live:
#   [ ] File is 0600, owned by the gvm runtime user
#   [ ] File is on an encrypted volume (LUKS, EBS-encrypted)
#   [ ] File is NOT in git history (check `git log --all -- secrets.toml`)
#   [ ] $GVM_SECRETS_KEY is provisioned via systemd EnvironmentFile=
#       (mode 0400, owned by root) — NOT in shell history or .env
#   [ ] Backups (if any) are also encrypted; secrets.toml is excluded
#       from any unencrypted backup target
#   [ ] Key rotation plan exists: how to mint new keys, replay
#       encrypted file, switch atomically. Document in your runbook.
#
# Credential injection contract:
#   - Agent makes request → proxy strips agent-supplied auth headers
#     (Authorization, Cookie, X-API-Key) and injects the managed
#     credential from this file.
#   - Agent never sees the raw key. Memory dump of the agent yields
#     no usable secret.
#   - This is enforced at the HTTP layer ONLY. Body-level credentials
#     (e.g., GraphQL variables) are NOT injected — agents must pass
#     such operations through, governed by SRR pattern matching.
#   - LLM SDK initialization (Anthropic, OpenAI) requires the key at
#     client construction; proxy cannot help there. Use the standard
#     env var (ANTHROPIC_API_KEY) for the LLM call itself; this file
#     governs tool API calls (Stripe, Slack, GitHub, …) the agent
#     makes after receiving tool_use from the LLM.
#
# ════════════════════════════════════════════════════════════════════

# ─── Payment / Finance ──────────────────────────────────────────────

# [credentials."api.stripe.com"]
# type = "ApiKey"
# header = "Authorization"
# value = "Bearer sk_live_REPLACE_ME"

# ─── Communication ──────────────────────────────────────────────────

# [credentials."slack.com"]
# type = "Bearer"
# token = "xoxb-REPLACE_ME"

# [credentials."api.sendgrid.com"]
# type = "ApiKey"
# header = "Authorization"
# value = "Bearer SG.REPLACE_ME"

# ─── Source / CI ────────────────────────────────────────────────────

# [credentials."api.github.com"]
# type = "Bearer"
# token = "ghp_REPLACE_ME"
#
# [credentials."gitlab.com"]
# type = "ApiKey"
# header = "PRIVATE-TOKEN"
# value = "REPLACE_ME"

# ─── Cloud APIs ─────────────────────────────────────────────────────
#
# Cloud SDKs typically use signed requests (SigV4 etc.) which the
# header-injection model does not cover. Run agents that use those
# SDKs with the IAM role-based credentials path managed by the
# environment (instance profile, workload identity), and govern the
# resulting outbound calls via SRR rules — not via this file.
#
# ────────────────────────────────────────────────────────────────────

# Each [credentials."<host>"] entry is opt-in. For a host that has NO
# entry here, the proxy does not inject — the agent's own auth header
# (if any) passes through unchanged. This means rolling out managed
# credentials can be done host-by-host without breaking flows.
