# GVM Agent Container — Layer 3: OS-Level Containment
#
# **EXPERIMENTAL — under construction.** This Dockerfile builds the
# `gvm-agent:latest` image that `gvm run --contained` runs scripts
# inside. The Docker isolation primitives work (read-only FS,
# no-new-privileges, NET_ADMIN drop, resource limits). The
# in-container DNAT to MITM, CA injection, and HTTPS_PROXY env-strip
# are not yet implemented; today's contained mode relies on the
# host-side iptables egress lock for governance, not in-container
# transparent interception. For full HTTPS L7 inspection use
# `--sandbox` on Linux.
#
# Multi-runtime agent image: Python 3.12 + Node.js 22 + OpenClaw.
# Supports Python agents (requests, SDK) and TypeScript agents (OpenClaw).
#
# Security properties:
# - Agent cannot reach external APIs directly (Docker network isolation)
# - Agent can only reach gvm-proxy via DNAT (443 → MITM listener)
# - No host filesystem access (read-only root, tmpfs for /tmp)
# - No privilege escalation (no-new-privileges, non-root user)
# - Resource limits enforced by Docker (CPU, memory)
#
# Usage:
#   gvm run --contained agent.py                    # Python agent
#   gvm run --contained -- openclaw agent --local   # OpenClaw agent
#   gvm run --contained -- node my_agent.js         # Node.js agent

FROM python:3.12-slim

# Install system dependencies:
# - iptables: required for DNAT MITM TLS inspection
# - ca-certificates: system trust store for MITM CA injection
# - curl: for Node.js installation and health checks
# - gnupg: for NodeSource GPG key
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        iptables ca-certificates curl gnupg && \
    rm -rf /var/lib/apt/lists/*

# Install Node.js 22 LTS (required for OpenClaw)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/* && \
    node --version && npm --version

# Install OpenClaw globally
RUN npm install -g openclaw && \
    openclaw --version && \
    rm -rf /root/.npm/_cacache

# Install Python packages
RUN pip install --no-cache-dir requests && rm -rf /root/.cache/pip

# Create non-root user
RUN groupadd -r gvm-agent && useradd -r -g gvm-agent -d /home/agent -m agent

# Agent workspace
WORKDIR /home/agent/workspace

# Don't switch to non-root yet — entrypoint may need root for iptables DNAT.
# The actual agent process drops privileges after setup.

# No ENTRYPOINT: `gvm run --contained` always passes the full command
# (interpreter + script path) as the CMD, so a hardcoded ENTRYPOINT
# would prepend itself and double-up the interpreter.
#
# Earlier this image had `ENTRYPOINT ["python"]`. With
# `gvm run --contained agent.py` the CLI passed
# `["python", "/home/agent/workspace/agent.py"]` to docker, which
# combined with the entrypoint became `python python /home/agent/...`
# — python treated the first "python" as the script path and failed
# with `can't open file '.../python'`. Removing the entrypoint lets
# CMD stand alone, matching exactly what the CLI builds.
#
# Default CMD is a noisy notice if someone runs the image directly
# without going through gvm — we don't want a silent shell.
CMD ["echo", "Run via: gvm run --contained <script>"]
