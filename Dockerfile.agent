# GVM Agent Container — Layer 3: OS-Level Containment
#
# This container isolates AI agents so they can ONLY communicate through
# the GVM proxy. Direct API access is blocked by Docker network rules.
#
# Security properties:
# - Agent cannot reach external APIs directly (network isolation)
# - Agent can only reach gvm-proxy on the gvm-internal network
# - No host filesystem access (read-only root, tmpfs for /tmp)
# - No privilege escalation (no-new-privileges, non-root user)
# - Resource limits enforced by Docker (CPU, memory)
#
# Usage:
#   gvm run --image my-agent:latest
#   # or manually:
#   docker run --network gvm-internal --env HTTP_PROXY=http://gvm-proxy:8080 my-agent

FROM python:3.12-slim

# Install iptables (required for DNAT MITM TLS inspection) and
# ca-certificates (for system trust store). Without iptables,
# contained mode cannot redirect HTTPS to the MITM proxy.
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends iptables ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user for agent execution
RUN groupadd -r gvm-agent && useradd -r -g gvm-agent -d /home/agent -m agent

# Install GVM Python SDK if available (optional — base image works without it)
# COPY sdk/python/ /opt/gvm-sdk/
# RUN pip install --no-cache-dir /opt/gvm-sdk/ && rm -rf /opt/gvm-sdk/

# Proxy env vars are set by gvm run --contained at runtime (not baked in).
# This allows the CLI to control proxy routing per-session.

# Agent workspace
WORKDIR /home/agent/workspace

# Switch to non-root user
USER agent

# Default: run the agent script mounted at /home/agent/workspace/agent.py
ENTRYPOINT ["python"]
CMD ["agent.py"]
