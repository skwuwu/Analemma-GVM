# GVM Agent Container — Layer 3: OS-Level Containment
#
# Multi-runtime agent image: Python 3.12 + Node.js 22 + OpenClaw.
# Supports Python agents (requests, SDK) and TypeScript agents (OpenClaw).
#
# Security properties:
# - Agent cannot reach external APIs directly (Docker network isolation)
# - Agent can only reach gvm-proxy via DNAT (443 → MITM listener)
# - No host filesystem access (read-only root, tmpfs for /tmp)
# - No privilege escalation (no-new-privileges, non-root user)
# - Resource limits enforced by Docker (CPU, memory)
#
# Usage:
#   gvm run --contained agent.py                    # Python agent
#   gvm run --contained -- openclaw agent --local   # OpenClaw agent
#   gvm run --contained -- node my_agent.js         # Node.js agent

FROM python:3.12-slim

# Install system dependencies:
# - iptables: required for DNAT MITM TLS inspection
# - ca-certificates: system trust store for MITM CA injection
# - curl: for Node.js installation and health checks
# - gnupg: for NodeSource GPG key
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        iptables ca-certificates curl gnupg && \
    rm -rf /var/lib/apt/lists/*

# Install Node.js 22 LTS (required for OpenClaw)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/* && \
    node --version && npm --version

# Install OpenClaw globally
RUN npm install -g openclaw && \
    openclaw --version && \
    rm -rf /root/.npm/_cacache

# Install Python packages
RUN pip install --no-cache-dir requests && rm -rf /root/.cache/pip

# Create non-root user
RUN groupadd -r gvm-agent && useradd -r -g gvm-agent -d /home/agent -m agent

# Agent workspace
WORKDIR /home/agent/workspace

# Don't switch to non-root yet — entrypoint may need root for iptables DNAT.
# The actual agent process drops privileges after setup.

# Default entrypoint: detect script type and run appropriate interpreter.
# Overridden by gvm run --contained which passes explicit command.
ENTRYPOINT ["python"]
CMD ["agent.py"]
